{
  "permissions": {
    "allow": [
      "Read",
      "Agent",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout -b *)",
      "Bash(git fetch*)",
      "Bash(git branch*)",
      "Bash(git push -u *)",
      "Bash(gh pr *)",
      "Bash(ls *)",
      "Bash(npm test*)",
      "Bash(npm run *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git checkout .)",
      "Bash(git clean *)"
    ]
  }
}
